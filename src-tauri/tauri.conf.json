{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Forge PDF",
  "version": "1.0.0",
  "identifier": "com.forgepdf.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "cd .. && npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../client/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Forge PDF",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/chromium": "chromium",
      "resources/licenses": "licenses"
    },
    "externalBin": [
      "binaries/server"
    ]
  }
}
