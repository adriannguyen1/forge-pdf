    "@types/express": "^5.0.6",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "@vercel/ncc": "^0.38.0",
    "@yao-pkg/pkg": "^6.0.0",
    "puppeteer": "^24.40.0",
